# MongoDB
MONGODB_URI=mongodb+srv://your-connection-string

# JWT Auth
JWT_SECRET=your_random_secret_minimum_32_characters
JWT_EXPIRY=8h
ADMIN_EMAIL=youradmin@gmail.com
ADMIN_PASSWORD=your_secure_password
# Or use bcrypt hash (recommended for production):
# ADMIN_PASSWORD_HASH=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Site URL (SEO + password reset / OTP emails)
# On Vercel set this to your production domain, e.g. https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Real-time chat across Vercel instances (Upstash Redis — add via Vercel Marketplace)
# vercel integration add upstash
REDIS_URL=rediss://default:password@host.upstash.io:6379

# SMTP — required in production to email admin OTPs (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youradmin@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="College Admin <youradmin@gmail.com>"
