{
  "name": "scholarshine-backend",
  "version": "1.0.0",
  "description": "Scholarshine Connect Backend API Server",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc",
    "prestart": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/server.js')){console.warn('dist/server.js not found — attempting to build'); process.exit(0);}\"",
    "start": "node ./scripts/start.cjs",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "express",
    "mongodb",
    "socket.io",
    "api",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.40.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^1.4.4",
    "socket.io": "^4.6.0",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "mongodb-memory-server": "^8.12.1",
    "@types/streamifier": "^0.1.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
