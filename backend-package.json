{
  "name": "scholarshine-backend",
  "version": "1.0.0",
  "description": "Scholarshine Connect Backend Server with Socket.io",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev": "ts-node-esm server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "mongoose": "^8.0.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.1.2",
    "cloudinary": "^1.41.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
